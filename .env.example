# OpenAI API key (for GPT models via OpenAI directly)
OPENAI_API_KEY=sk-...

# Azure OpenAI (for GPT models via Azure)
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Anthropic proxy base URL
ANTHROPIC_BASE_URL=http://localhost:23333/api/anthropic

# DeepSeek API key
DEEPSEEK_API_KEY=sk-...

# KIMI / Moonshot AI API key
KIMI_API_KEY=sk-...
